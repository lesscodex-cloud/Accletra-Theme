---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Accletra - SaaS & Startup Astro Theme">
  <section class="py-20">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl font-bold">Build Your SaaS with Accletra & Astro</h1>
      <p class="mt-4 text-lg">A modern, responsive, and high-performing theme for your next startup.</p>
      <a href="/features" class="mt-8 inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold">Learn More</a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl font-bold">Features</h2>
      <div class="mt-12 grid md:grid-cols-3 gap-8">
        <div class="p-8 border rounded-lg">
          <h3 class="text-xl font-bold">Astro-Powered</h3>
          <p class="mt-2">Blazing fast performance with Astro's innovative island architecture.</p>
        </div>
        <div class="p-8 border rounded-lg">
          <h3 class="text-xl font-bold">Tailwind CSS</h3>
          <p class="mt-2">A utility-first CSS framework for rapid UI development.</p>
        </div>
        <div class="p-8 border rounded-lg">
          <h3 class="text-xl font-bold">Fully Responsive</h3>
          <p class="mt-2">Looks great on all devices, from mobile to desktop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl font-bold">Ready to Get Started?</h2>
      <p class="mt-4 text-lg">Launch your startup with Accletra today.</p>
      <a href="/pricing" class="mt-8 inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold">View Pricing</a>
    </div>
  </section>
</BaseLayout>