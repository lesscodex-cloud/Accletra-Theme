---
import BaseLayout from '../layouts/BaseLayout.astro';
const allPosts = await Astro.glob('../content/blog/*.md');
---
<BaseLayout title="Blog - Accletra">
  <section class="py-20">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl font-bold">Blog</h1>
      <p class="mt-4 text-lg">News, updates, and thoughts from the Accletra team.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        {allPosts.map((post) => (
          <a href={post.url} class="block p-8 border rounded-lg">
            <h3 class="text-2xl font-bold">{post.frontmatter.title}</h3>
            <p class="mt-4">{post.frontmatter.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>