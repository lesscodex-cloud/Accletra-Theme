---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Features - Accletra">
  <section class="py-20">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl font-bold">Accletra Features</h1>
      <p class="mt-4 text-lg">Everything you need to build a stunning SaaS website.</p>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="container mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="p-8 border rounded-lg">
          <h3 class="text-2xl font-bold">Astro-Powered</h3>
          <p class="mt-4">Experience blazing-fast load times and optimal performance thanks to Astro's next-gen architecture. By shipping zero JavaScript by default, Astro ensures your site is fast and SEO-friendly.</p>
        </div>
        <div class="p-8 border rounded-lg">
          <h3 class="text-2xl font-bold">Tailwind CSS</h3>
          <p class="mt-4">Utilize the power of Tailwind CSS for rapid UI development. With a utility-first approach, you can build custom designs without writing a single line of custom CSS.</p>
        </div>
        <div class="p-8 border rounded-lg">
          <h3 class="text-2xl font-bold">Fully Responsive</h3>
          <p class="mt-4">Accletra is designed to look stunning on all devices. Whether your users are on a desktop, tablet, or smartphone, your website will provide a seamless experience.</p>
        </div>
        <div class="p-8 border rounded-lg">
          <h3 class="text-2xl font-bold">SEO Optimized</h3>
          <p class="mt-4">Built with SEO best practices in mind, Accletra helps you rank higher in search results. From semantic HTML to meta tags, everything is optimized for search engines.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>